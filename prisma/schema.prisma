generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

enum WmsRol {
  configurador
  administrador_cuenta
  operador_cuenta
  administrador_bodega
  jefe_bodega
  custodio
  operario
  procesador
  transportista

  @@map("wms_rol")
}

enum RolNivel {
  plataforma
  cuenta
  bodega

  @@map("rol_nivel")
}

enum EstadoSolicitudCompra {
  borrador
  pendiente_aprobacion
  aprobada
  rechazada
  convertida
  cancelada

  @@map("estado_solicitud_compra")
}

enum EstadoOrdenCompra {
  borrador
  emitida
  parcialmente_recibida
  recibida
  cerrada
  cancelada

  @@map("estado_orden_compra")
}

enum TipoMovimiento {
  entrada
  salida
  recepcion
  despacho
  transferencia
  ajuste_positivo
  ajuste_negativo
  merma
  reserva
  liberacion_reserva
  consumo_ot
  produccion_ot

  @@map("tipo_movimiento")
}

enum TipoAuditoria {
  creacion
  actualizacion
  eliminacion
  cambio_estado
  movimiento_inventario
  acceso_denegado

  @@map("tipo_auditoria")
}

enum EstadoOrdenTrabajo {
  planificada
  en_proceso
  pausada
  completada
  cancelada

  @@map("estado_orden_trabajo")
}

enum TipoOrdenTrabajo {
  picking
  merma
  transformacion
  reabasto
  conteo
  otro

  @@map("tipo_orden_trabajo")
}

enum TipoLineaOt {
  entrada
  salida
  subproducto

  @@map("tipo_linea_ot")
}

enum EstadoOrdenVenta {
  borrador
  confirmada
  en_preparacion
  parcialmente_despachada
  despachada
  cerrada
  cancelada

  @@map("estado_orden_venta")
}

enum EstadoViajeTransporte {
  programado
  en_ruta
  entregado
  cancelado

  @@map("estado_viaje_transporte")
}

enum EstadoGuiaEnvio {
  generada
  asignada
  en_transito
  entregada
  anulada

  @@map("estado_guia_envio")
}

enum TipoEvidenciaTransporte {
  foto
  firma

  @@map("tipo_evidencia_transporte")
}

enum BodegaTipo {
  interna
  externa

  @@map("bodega_tipo")
}

enum EstadoSolicitudBodega {
  pendiente
  atendida
  rechazada
  cancelada

  @@map("estado_solicitud_bodega")
}

enum DestinoTipo {
  interna
  externa

  @@map("destino_tipo")
}

enum EstadoSlot {
  libre
  ocupado
  reservado
  en_proceso

  @@map("estado_slot")
}

enum EstadoLote {
  activo
  bloqueado
  vencido
  agotado

  @@map("estado_lote")
}

enum TipoCamion {
  refrigerado
  seco
  isotermico

  @@map("tipo_camion")
}

enum EstadoProcesamiento {
  borrador
  pendiente
  en_proceso
  pendiente_cierre
  terminada
  cancelada

  @@map("estado_procesamiento")
}

enum TipoAlerta {
  temperatura
  demora
  orden_reportada
  otro

  @@map("tipo_alerta")
}

enum EstadoAlerta {
  abierta
  cerrada

  @@map("estado_alerta")
}

enum TipoTarea {
  ingreso
  movimiento
  despacho
  procesamiento
  revision
  otro

  @@map("tipo_tarea")
}

enum EstadoTarea {
  pendiente
  en_proceso
  completada
  cancelada

  @@map("estado_tarea")
}

enum EstadoTareaCuenta {
  pendiente
  resuelta

  @@map("estado_tarea_cuenta")
}

enum EstadoIntegracion {
  activo
  finalizado

  @@map("estado_integracion")
}

model Rol {
  idRol         WmsRol   @id @map("id_rol")
  nombre        String   @db.VarChar(255)
  nivel         RolNivel
  puedeCrearRol WmsRol?  @map("puede_crear_rol")
  descripcion   String?
  usuarios      Usuario[]
  asignaciones  AsignacionBodega[]

  @@map("rol")
}

model Empresa {
  codigoEmpresa         String                @id @map("codigo_empresa") @db.VarChar(32)
  razonSocial           String                @map("razon_social") @db.VarChar(255)
  estaActiva            Boolean               @default(true) @map("esta_activa")
  idCreador             String?               @map("id_creador") @db.Uuid
  createdAt             DateTime              @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt             DateTime              @updatedAt @map("updated_at") @db.Timestamptz(6)
  usuarios              Usuario[]
  cuentas               Cuenta[]
  solicitudesAltaBodega SolicitudAltaBodega[]

  @@map("empresa")
}

model Cuenta {
  codigoCuenta       String              @id @map("codigo_cuenta") @db.VarChar(32)
  codigoEmpresa      String              @map("codigo_empresa") @db.VarChar(32)
  nombreComercial    String              @map("nombre_comercial") @db.VarChar(255)
  estaActiva         Boolean             @default(true) @map("esta_activa")
  idCreador          String?             @map("id_creador") @db.Uuid
  createdAt          DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime            @updatedAt @map("updated_at") @db.Timestamptz(6)
  empresa            Empresa             @relation(fields: [codigoEmpresa], references: [codigoEmpresa])
  usuarios           Usuario[]
  bodegas            Bodega[]
  tiposUbicacion     TipoUbicacion[]
  zonas              Zona[]
  ubicaciones        Ubicacion[]
  proveedores        Proveedor[]
  clientes           Cliente[]
  productos          Producto[]
  compradores        Comprador[]
  plantas            Planta[]
  camiones           Camion[]
  solicitudesCompra  SolicitudCompra[]
  ordenesCompra      OrdenCompra[]
  lotes              Lote[]
  warehouseStates    WarehouseState[]
  movimientos        MovimientoInventario[]
  contadores         Contador[]
  auditorias         AuditoriaOperacion[]
  ordenesTrabajo     OrdenTrabajo[]
  ordenesVenta       OrdenVenta[]
  viajesTransporte        ViajeTransporte[]
  solicitudesAltaBodega   SolicitudAltaBodega[]
  recepcionesCompra       RecepcionCompra[]
  solicitudesProcesamiento SolicitudProcesamiento[]
  registrosMerma          RegistroMerma[]
  alertasOperativas       AlertaOperativa[]
  tareasCola              TareaCola[]
  solicitudesIntegracion  SolicitudIntegracion[]
  tareasCuenta            TareaCuenta[]

  @@map("cuenta")
}

model Bodega {
  idBodega           String                 @id @default(dbgenerated("gen_random_uuid()")) @map("id_bodega") @db.Uuid
  codigoCuenta       String                 @map("codigo_cuenta") @db.VarChar(32)
  codigo             String                 @db.VarChar(32)
  nombre             String                 @db.VarChar(255)
  tipo               BodegaTipo             @default(interna)
  capacidadSlots     Int?                   @map("capacidad_slots")
  idSolicitudOrigen  String?                @map("id_solicitud_origen") @db.Uuid
  idCreador          String?                @map("id_creador") @db.Uuid
  estaActiva         Boolean                @default(true) @map("esta_activa")
  createdAt          DateTime               @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime               @updatedAt @map("updated_at") @db.Timestamptz(6)
  cuenta             Cuenta                 @relation(fields: [codigoCuenta], references: [codigoCuenta])
  solicitudOrigen    SolicitudAltaBodega?   @relation("BodegaDesdeSolicitud", fields: [idSolicitudOrigen], references: [idSolicitud])
  creador            Usuario?               @relation("BodegaCreador", fields: [idCreador], references: [idUsuario])
  asignaciones       AsignacionBodega[]
  tiposUbicacion     TipoUbicacion[]
  zonas              Zona[]
  ubicaciones        Ubicacion[]
  solicitudesCompra  SolicitudCompra[]
  ordenesCompra      OrdenCompra[]
  lotes              Lote[]
  warehouseStates    WarehouseState[]
  movimientos        MovimientoInventario[]
  contadores         Contador[]
  auditorias         AuditoriaOperacion[]
  ordenesTrabajo     OrdenTrabajo[]
  ordenesVenta       OrdenVenta[]
  viajesTransporte          ViajeTransporte[]
  recepcionesCompra         RecepcionCompra[]
  solicitudesProcesamiento  SolicitudProcesamiento[]
  registrosMerma            RegistroMerma[]
  alertasOperativas         AlertaOperativa[]
  tareasCola                TareaCola[]
  ordenesVentaDestino       OrdenVenta[]             @relation("OrdenVentaBodegaDestino")
  solicitudesAltaAtendidas  SolicitudAltaBodega[]    @relation("SolicitudBodegaCreada")

  @@unique([codigoCuenta, codigo], map: "uq_bodega_cuenta_codigo")
  @@map("bodega")
}

model SolicitudAltaBodega {
  idSolicitud       String                @id @default(dbgenerated("gen_random_uuid()")) @map("id_solicitud") @db.Uuid
  codigoEmpresa     String                @map("codigo_empresa") @db.VarChar(32)
  codigoCuenta      String                @map("codigo_cuenta") @db.VarChar(32)
  idSolicitante     String                @map("id_solicitante") @db.Uuid
  nombreSolicitado  String                @map("nombre_solicitado") @db.VarChar(255)
  tipo              BodegaTipo            @default(interna)
  comentarios       String?
  estado            EstadoSolicitudBodega @default(pendiente)
  idBodega          String?               @map("id_bodega") @db.Uuid
  idAtendidoPor     String?               @map("id_atendido_por") @db.Uuid
  createdAt         DateTime              @default(now()) @map("created_at") @db.Timestamptz(6)
  atendidoEn        DateTime?             @map("atendido_en") @db.Timestamptz(6)
  empresa           Empresa               @relation(fields: [codigoEmpresa], references: [codigoEmpresa])
  cuenta            Cuenta                @relation(fields: [codigoCuenta], references: [codigoCuenta])
  solicitante       Usuario               @relation("SolicitudAltaSolicitante", fields: [idSolicitante], references: [idUsuario])
  atendidoPor       Usuario?              @relation("SolicitudAltaAtendido", fields: [idAtendidoPor], references: [idUsuario])
  bodegaCreada      Bodega?               @relation("SolicitudBodegaCreada", fields: [idBodega], references: [idBodega])
  bodegasOrigen     Bodega[]              @relation("BodegaDesdeSolicitud")

  @@map("solicitud_alta_bodega")
}

model AsignacionBodega {
  idAsignacion  String   @id @default(dbgenerated("gen_random_uuid()")) @map("id_asignacion") @db.Uuid
  idUsuario     String   @map("id_usuario") @db.Uuid
  idBodega      String   @map("id_bodega") @db.Uuid
  idRol         WmsRol   @map("id_rol")
  vigenteDesde  DateTime @default(now()) @map("vigente_desde") @db.Timestamptz(6)
  estaActiva    Boolean  @default(true) @map("esta_activa")
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  usuario Usuario @relation(fields: [idUsuario], references: [idUsuario], onDelete: Cascade)
  bodega  Bodega  @relation(fields: [idBodega], references: [idBodega], onDelete: Cascade)
  rol     Rol     @relation(fields: [idRol], references: [idRol])

  @@unique([idUsuario, idBodega], map: "uq_asignacion_usuario_bodega")
  @@map("asignacion_bodega")
}

model Usuario {
  idUsuario              String                 @id @default(dbgenerated("gen_random_uuid()")) @map("id_usuario") @db.Uuid
  idAuth                 String                 @unique @map("id_auth") @db.Uuid
  idRol                  WmsRol                 @map("id_rol")
  codigoEmpresa          String?                @map("codigo_empresa") @db.VarChar(32)
  codigoCuenta           String?                @map("codigo_cuenta") @db.VarChar(32)
  idCreador              String?                @map("id_creador") @db.Uuid
  nombre                 String                 @db.VarChar(255)
  username               String                 @unique
  correo                 String                 @unique
  estaActivo             Boolean                @default(true) @map("esta_activo")
  createdAt              DateTime               @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt              DateTime               @updatedAt @map("updated_at") @db.Timestamptz(6)
  rol                    Rol                    @relation(fields: [idRol], references: [idRol])
  empresa                Empresa?               @relation(fields: [codigoEmpresa], references: [codigoEmpresa])
  cuenta                 Cuenta?                @relation(fields: [codigoCuenta], references: [codigoCuenta])
  asignacionesBodega        AsignacionBodega[]
  solicitudesCompra        SolicitudCompra[]
  warehouseStatesLocked    WarehouseState[]       @relation("WarehouseStateLockedBy")
  movimientosInventario    MovimientoInventario[]
  auditoriasOperacion      AuditoriaOperacion[]
  ordenesTrabajoAsignadas  OrdenTrabajo[]         @relation("OrdenTrabajoAsignado")
  ordenesTrabajoSolicitadas OrdenTrabajo[]        @relation("OrdenTrabajoSolicitante")
  viajesComoTransportista  ViajeTransporte[]      @relation("ViajeTransportista")
  bodegasCreadas           Bodega[]               @relation("BodegaCreador")
  solicitudesAltaCreadas   SolicitudAltaBodega[]  @relation("SolicitudAltaSolicitante")
  solicitudesAltaAtendidas SolicitudAltaBodega[]  @relation("SolicitudAltaAtendido")
  ordenesCompraCreadas     OrdenCompra[]          @relation("OrdenCompraCreador")
  ordenesVentaCreadas      OrdenVenta[]           @relation("OrdenVentaCreador")
  recepcionesCerradas      RecepcionCompra[]      @relation("RecepcionCerradaPor")
  solicitudesProcesamientoSolicitadas SolicitudProcesamiento[] @relation("SolicitudProcSolicitante")
  solicitudesProcesamientoAsignadas   SolicitudProcesamiento[] @relation("SolicitudProcProcesador")
  alertasResponsable       AlertaOperativa[]      @relation("AlertaResponsable")
  tareasAsignadas          TareaCola[]            @relation("TareaColaAsignado")
  solicitudesIntegracion   SolicitudIntegracion[] @relation("SolicitudIntegracionSolicitante")
  tareasCuentaCreadas      TareaCuenta[]          @relation("TareaCuentaCreador")

  @@map("usuario")
}

model TipoUbicacion {
  idTipoUbicacion   String      @id @default(dbgenerated("gen_random_uuid()")) @map("id_tipo_ubicacion") @db.Uuid
  codigoCuenta      String      @map("codigo_cuenta") @db.VarChar(32)
  idBodega          String      @map("id_bodega") @db.Uuid
  codigo            String      @db.VarChar(32)
  nombre            String      @db.VarChar(255)
  esPicking         Boolean     @default(false) @map("es_picking")
  esRecepcion       Boolean     @default(false) @map("es_recepcion")
  esAlmacenamiento  Boolean     @default(true) @map("es_almacenamiento")
  estaActiva        Boolean     @default(true) @map("esta_activa")
  createdAt         DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime    @updatedAt @map("updated_at") @db.Timestamptz(6)
  cuenta            Cuenta      @relation(fields: [codigoCuenta], references: [codigoCuenta])
  bodega            Bodega      @relation(fields: [idBodega], references: [idBodega])
  ubicaciones       Ubicacion[]

  @@unique([idBodega, codigo], map: "uq_tipo_ubicacion_bodega_codigo")
  @@map("tipo_ubicacion")
}

model Zona {
  idZona       String      @id @default(dbgenerated("gen_random_uuid()")) @map("id_zona") @db.Uuid
  codigoCuenta String      @map("codigo_cuenta") @db.VarChar(32)
  idBodega     String      @map("id_bodega") @db.Uuid
  codigo       String      @db.VarChar(32)
  nombre       String      @db.VarChar(255)
  estaActiva   Boolean     @default(true) @map("esta_activa")
  createdAt    DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime    @updatedAt @map("updated_at") @db.Timestamptz(6)
  cuenta       Cuenta      @relation(fields: [codigoCuenta], references: [codigoCuenta])
  bodega       Bodega      @relation(fields: [idBodega], references: [idBodega])
  ubicaciones  Ubicacion[]

  @@unique([idBodega, codigo], map: "uq_zona_bodega_codigo")
  @@map("zona")
}

model Ubicacion {
  idUbicacion     String                 @id @default(dbgenerated("gen_random_uuid()")) @map("id_ubicacion") @db.Uuid
  codigoCuenta    String                 @map("codigo_cuenta") @db.VarChar(32)
  idBodega        String                 @map("id_bodega") @db.Uuid
  idZona          String?                @map("id_zona") @db.Uuid
  idTipoUbicacion String                 @map("id_tipo_ubicacion") @db.Uuid
  codigo          String                 @db.VarChar(64)
  capacidad       Decimal?               @db.Decimal(18, 4)
  estadoSlot      EstadoSlot             @default(libre) @map("estado_slot")
  estaActiva      Boolean                @default(true) @map("esta_activa")
  createdAt       DateTime               @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime               @updatedAt @map("updated_at") @db.Timestamptz(6)
  cuenta          Cuenta                 @relation(fields: [codigoCuenta], references: [codigoCuenta])
  bodega          Bodega                 @relation(fields: [idBodega], references: [idBodega])
  zona            Zona?                  @relation(fields: [idZona], references: [idZona])
  tipoUbicacion   TipoUbicacion          @relation(fields: [idTipoUbicacion], references: [idTipoUbicacion])
  warehouseStates WarehouseState[]
  movimientosOrigen  MovimientoInventario[] @relation("MovimientoUbicacionOrigen")
  movimientosDestino MovimientoInventario[] @relation("MovimientoUbicacionDestino")
  lineasOrdenTrabajo       OrdenTrabajoLinea[]
  ordenesTrabajoOrigen     OrdenTrabajo[]         @relation("OrdenTrabajoUbicacionOrigen")
  ordenesTrabajoDestino    OrdenTrabajo[]         @relation("OrdenTrabajoUbicacionDestino")
  alertasOperativas        AlertaOperativa[]

  @@unique([idBodega, codigo], map: "uq_ubicacion_bodega_codigo")
  @@map("ubicacion")
}

model Proveedor {
  idProveedor   String        @id @default(dbgenerated("gen_random_uuid()")) @map("id_proveedor") @db.Uuid
  codigoCuenta  String        @map("codigo_cuenta") @db.VarChar(32)
  codigo        String        @db.VarChar(32)
  razonSocial   String        @map("razon_social") @db.VarChar(255)
  telefono      String?       @db.VarChar(32)
  email         String?
  estaActivo    Boolean       @default(true) @map("esta_activo")
  createdAt     DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime      @updatedAt @map("updated_at") @db.Timestamptz(6)
  cuenta        Cuenta        @relation(fields: [codigoCuenta], references: [codigoCuenta])
  ordenesCompra OrdenCompra[]
  solicitudesCompra SolicitudCompra[]

  @@unique([codigoCuenta, codigo], map: "uq_proveedor_cuenta_codigo")
  @@map("proveedor")
}

model Cliente {
  idCliente              String                   @id @default(dbgenerated("gen_random_uuid()")) @map("id_cliente") @db.Uuid
  codigoCuenta           String                   @map("codigo_cuenta") @db.VarChar(32)
  codigo                 String                   @db.VarChar(32)
  nombre                 String                   @db.VarChar(255)
  nit                    String?                  @db.VarChar(32)
  estaActivo             Boolean                  @default(true) @map("esta_activo")
  createdAt              DateTime                 @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt              DateTime                 @updatedAt @map("updated_at") @db.Timestamptz(6)
  cuenta                 Cuenta                   @relation(fields: [codigoCuenta], references: [codigoCuenta])
  ordenesVenta           OrdenVenta[]
  productos              Producto[]
  lotes                  Lote[]
  solicitudesProcesamiento SolicitudProcesamiento[]
  solicitudesIntegracion SolicitudIntegracion[]
  tareasCuenta           TareaCuenta[]

  @@unique([codigoCuenta, codigo], map: "uq_cliente_cuenta_codigo")
  @@map("cliente")
}

model Producto {
  idProducto                        String                 @id @default(dbgenerated("gen_random_uuid()")) @map("id_producto") @db.Uuid
  codigoCuenta                      String                 @map("codigo_cuenta") @db.VarChar(32)
  idCliente                         String?                @map("id_cliente") @db.Uuid
  sku                               String                 @db.VarChar(64)
  descripcion                       String                 @db.VarChar(512)
  unidadMedida                      String                 @map("unidad_medida") @db.VarChar(32)
  esPrimario                        Boolean                @default(false) @map("es_primario")
  esSecundario                      Boolean                @default(false) @map("es_secundario")
  codigoAlmacen                     String?                @map("codigo_almacen") @db.VarChar(32)
  idProductoPrimario                String?                @map("id_producto_primario") @db.Uuid
  reglaConversionCantidadPrimario   Decimal?               @map("regla_conversion_cantidad_primario") @db.Decimal(18, 4)
  reglaConversionUnidadesSecundario Decimal?               @map("regla_conversion_unidades_secundario") @db.Decimal(18, 4)
  mermaPct                          Decimal?               @map("merma_pct") @db.Decimal(5, 2)
  unidadVisualizacion               String                 @default("peso") @map("unidad_visualizacion") @db.VarChar(32)
  requiereLote                      Boolean                @default(false) @map("requiere_lote")
  metadatosCatalogo                 Json?                  @map("metadatos_catalogo")
  estaActivo                        Boolean                @default(true) @map("esta_activo")
  createdAt                         DateTime               @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt                         DateTime               @updatedAt @map("updated_at") @db.Timestamptz(6)
  cuenta                            Cuenta                 @relation(fields: [codigoCuenta], references: [codigoCuenta])
  cliente                           Cliente?               @relation(fields: [idCliente], references: [idCliente])
  productoPrimario                  Producto?              @relation("ProductoSecundarioDe", fields: [idProductoPrimario], references: [idProducto])
  productosSecundarios              Producto[]             @relation("ProductoSecundarioDe")
  lineasSolicitud                   SolicitudCompraLinea[]
  lineasOrdenCompra                 OrdenCompraLinea[]
  lotes                             Lote[]
  warehouseStates                   WarehouseState[]
  movimientos                       MovimientoInventario[]
  lineasOrdenTrabajo                OrdenTrabajoLinea[]
  lineasOrdenVenta                  OrdenVentaLinea[]
  solicitudesProcPrimario           SolicitudProcesamiento[] @relation("SolicitudProcPrimario")
  solicitudesProcSecundario         SolicitudProcesamiento[] @relation("SolicitudProcSecundario")
  lineasRecepcion                   RecepcionCompraLinea[]

  @@unique([codigoCuenta, sku], map: "uq_producto_cuenta_sku")
  @@map("producto")
}

model Comprador {
  idComprador  String       @id @default(dbgenerated("gen_random_uuid()")) @map("id_comprador") @db.Uuid
  codigoCuenta String       @map("codigo_cuenta") @db.VarChar(32)
  codigo       String       @db.VarChar(32)
  nombre       String       @db.VarChar(255)
  contacto     String?      @db.VarChar(255)
  estaActivo   Boolean      @default(true) @map("esta_activo")
  createdAt    DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime     @updatedAt @map("updated_at") @db.Timestamptz(6)
  cuenta       Cuenta       @relation(fields: [codigoCuenta], references: [codigoCuenta])
  ordenesVenta OrdenVenta[]

  @@unique([codigoCuenta, codigo], map: "uq_comprador_cuenta_codigo")
  @@map("comprador")
}

model Planta {
  idPlanta          String       @id @default(dbgenerated("gen_random_uuid()")) @map("id_planta") @db.Uuid
